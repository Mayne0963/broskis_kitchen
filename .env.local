# Firebase Configuration
# Firebase Configuration - These should be set in Vercel environment variables
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBroskisKitchenFirebaseApiKey
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=broskis-kitchen.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=broskis-kitchen
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=broskis-kitchen.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456789
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-BROSKISKITCHEN

# Google Maps API
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# OpenAI API
OPENAI_API_KEY=your-openai-api-key

# Age Verification
AGE_VERIFICATION_EXPIRY_DAYS=30

# Website URL
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3000

# Stripe Configuration
STRIPE_SECRET_KEY=your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key